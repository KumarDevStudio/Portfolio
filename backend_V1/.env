# ===========================
# FILE STORAGE (optional)
# ===========================
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_BUCKET_NAME=your-bucket-name
AWS_REGION=us-west-2

CLOUDINARY_CLOUD_NAME=dtqlbjvii
CLOUDINARY_API_KEY=493157472859971
CLOUDINARY_API_SECRET=BoNrzkppYLd9lhTwRami3Akn5aI

# ===========================
# LOGGING
# ===========================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=./logs/app.log
ERROR_LOG_FILE_PATH=./logs/error.log

# ===========================
# MONITORING
# ===========================
ERROR_MONITORING_URL=https://your-sentry-dsn@sentry.io/project-id
HEALTH_CHECK_ENABLED=true

# ===========================
# REDIS (optional)
# ===========================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
SESSION_SECRET=your-session-secret-key
SESSION_MAX_AGE=86400000

# ===========================
# CACHING
# ===========================
ENABLE_CACHE=true
CACHE_TYPE=memory   # memory | redis
CACHE_TTL=300       # seconds

# ===========================
# SECURITY
# ===========================
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900    # seconds (15m)

# ===========================
# RATE LIMITING
# ===========================
ENABLE_RATE_LIMITING=true
GENERAL_RATE_LIMIT=100      # per 15 min
LOGIN_RATE_LIMIT=5          # per 15 min
CONTACT_RATE_LIMIT=5        # per hour
PASSWORD_CHANGE_RATE_LIMIT=3 # per day

# ===========================
# FILE UPLOAD
# ===========================
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp,pdf,doc,docx
MAX_FILE_SIZE=5242880       # 5 MB
MAX_FILES_PER_UPLOAD=10

# ===========================
# DATABASE OPTIMIZATION
# ===========================
DB_MAX_POOL_SIZE=10
DB_MIN_POOL_SIZE=2
DB_SERVER_SELECTION_TIMEOUT=5000
DB_SOCKET_TIMEOUT=45000

# ===========================
# PERFORMANCE
# ===========================
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
COMPRESSION_THRESHOLD=1024
STATIC_CACHE_MAX_AGE=31536000

# ===========================
# SSL/TLS
# ===========================
SSL_ENABLED=false
SSL_CERT_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem

# ===========================
# API CONFIG
# ===========================
API_VERSION=v1
API_BASE_PATH=/api
VALID_API_KEYS=api-key-1,api-key-2,api-key-3

# ===========================
# WEBHOOK
# ===========================
WEBHOOK_SECRET=your-webhook-secret
WEBHOOK_TIMEOUT=30000

# ===========================
# THIRD-PARTY INTEGRATIONS
# ===========================
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
GITHUB_TOKEN=your-github-token
LINKEDIN_API_KEY=your-linkedin-api-key

# ===========================
# BACKUPS
# ===========================
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *    # daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket

# ===========================
# DEVELOPMENT
# ===========================
DEV_MODE=true
MOCK_EMAIL_SERVICE=true
MOCK_PAYMENT_SERVICE=true

# ===========================
# PRODUCTION OPTIMIZATIONS
# ===========================
CLUSTER_WORKERS=auto
NODE_OPTIONS=--max-old-space-size=4096
PM2_INSTANCES=max
PM2_EXEC_MODE=cluster

# ===========================
# CUSTOM APP SETTINGS
# ===========================
CONTACT_EMAIL_TO=contact@yourportfolio.com
CONTACT_EMAIL_SUBJECT_PREFIX=[Portfolio Contact]
FEATURED_PROJECTS_LIMIT=6
RECENT_PROJECTS_LIMIT=10
SKILLS_PER_CATEGORY_LIMIT=20
EXPERIENCE_DISPLAY_LIMIT=10

# ===========================
# FEATURE FLAGS
# ===========================
FEATURE_ADMIN_DASHBOARD=true
FEATURE_PROJECT_ANALYTICS=false
FEATURE_VISITOR_TRACKING=true
FEATURE_CONTACT_FORM=true
FEATURE_BLOG=false
FEATURE_TESTIMONIALS=false
